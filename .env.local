# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=staging
DEBUG=false

# App
APP_NAME=Production AI Agent
APP_VERSION=1.0.0

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Security
AGENT_API_KEY=my-secret-agent-key
JWT_SECRET=super-secret-jwt

# Rate & Budget
RATE_LIMIT_PER_MINUTE=20
DAILY_BUDGET_USD=5.0

# Storage (Dùng 'redis' làm host trong Docker Compose)
REDIS_URL=redis://redis:6379/0

# CORS
ALLOWED_ORIGINS=*
